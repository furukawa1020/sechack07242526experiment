{
  "name": "sechack-experiment-local",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "SecHack365 participant-study presentation system",
  "scripts": {
    "dev": "tsx src/server/index.ts",
    "preflight": "tsx scripts/preflight.ts",
    "healthcheck": "tsx scripts/healthcheck.ts",
    "release:create": "tsx scripts/create-release.ts",
    "release:verify": "tsx scripts/verify-release.ts",
    "deploy:prepare": "npm run lint && npm run typecheck && npm test && npm run test:e2e && npm run build && npm run release:create --",
    "build:client": "vite build",
    "build:public-demo": "vite build --config vite.public-demo.config.ts",
    "build:server": "node scripts/build-server.mjs",
    "build": "npm run build:client && npm run build:server",
    "start": "node dist-server/index.js",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.server.json --noEmit",
    "test": "vitest run --coverage",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:public-demo": "npm run build:public-demo && playwright test --config playwright.public-demo.config.ts",
    "screenshots": "playwright test tests/e2e/screenshots.spec.ts --project=chromium"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "express": "^5.2.1",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "serialport": "^13.0.0",
    "ws": "^8.21.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "esbuild": "^0.28.1",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.5",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
